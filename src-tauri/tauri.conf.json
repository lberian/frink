{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Frink",
  "version": "0.6.0",
  "identifier": "com.lberian.frink",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "publisher": "lberian",
    "copyright": "© 2026 Luis Berián (lberian)"
  }
}
